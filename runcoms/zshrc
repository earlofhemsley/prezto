# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...
bindkey -v

source ~/.zprezto/gha.zsh
source ~/.zprezto/aws.zsh

alias refresh="source ~/.zshrc"

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ......="cd ../../../../.."

alias config="vi ~/.zshrc"
alias refresh="source ~/.zshrc"
alias tf="terraform"

alias tos="${HOME}/bin/thinkorswim &> /dev/null &"

use-java () {
    local name=$1
    local pkg=$(update-java-alternatives -l | grep "${name}" | awk '{print $1}')
    sudo update-java-alternatives -s "${pkg}"
    echo "now using ${pkg}"
}

# local bin dir
export PATH="$HOME/bin:$PATH"

# claude code local path bin dir
export PATH="$HOME/.local/bin:$PATH"

# this is because i had to change where npm global packages are located
# because of EACCES (directory permissions) errors
# https://stackoverflow.com/a/29787931
export PATH=$HOME/.npm-global/bin:$PATH

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
